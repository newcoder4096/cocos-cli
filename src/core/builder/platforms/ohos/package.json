{
    "name": "ohos",
    "version": "1.0.0",
    "author": "Cocos",
    "description": "OHOS platform plugin",
    "license": "ISC",
    "type": "commonjs",
    "contributes": {
        "builder": {
            "register": true,
            "platform": "ohos",
            "config": "./src/config",
            "hooks": "./src/hooks"
        },
        "pinkBuilder": {
            "platform": "ohos",
            "customView": "./dist/view/build-config.js",
            "customExtensionHost": "./dist/view/build-config-host.js",
            "customFields": [
                "encrypted",
                "xxteaKey",
                "compressZip",
                "JobSystem"
            ]
        }
    },
    "scripts": {
        "build-view": "node scripts/build-view.js",
        "watch-view": "node scripts/build-view.js --watch"
    }
}